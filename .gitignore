# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
.qodo/

# Streamlit
.streamlit/secrets.toml

# Internal / private docs (tracker, deep dive, interview notes, etc.)
docs/

# Per-run outputs (user-specific, regenerated on every run)
data/outputs/*
!data/outputs/.gitkeep

# User-supplied sample clips (never commit video content)
data/samples/*
!data/samples/.gitkeep

# User-built reference embedding banks
data/reference_banks/*
!data/reference_banks/.gitkeep

# Logs and caches
*.log
.cache/
.pytest_cache/
*.egg-info/
build/
dist/

# Model / embedding caches (can get large)
*.npy
*.npz
*.pkl
*.joblib

# Downloaded video files (we intentionally avoid persisting source video)
*.mp4
*.mkv
*.webm
*.avi
*.mov
