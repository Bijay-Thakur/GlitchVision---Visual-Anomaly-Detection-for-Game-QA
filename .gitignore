# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
.qodo/

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# Streamlit local config and secrets
.streamlit/*.toml

# Internal / private docs (tracker, deep dive, interview notes, etc.)
docs/*
# Allow public docs and README screenshots through
!docs/MODEL_CARD.md
!docs/screenshots/

# Per-run outputs (user-specific, regenerated on every run)
data/outputs/*
!data/outputs/.gitkeep

# User-supplied sample clips (never commit video content)
data/samples/*
!data/samples/.gitkeep

# User-built reference embedding banks and local model artifacts
data/reference_banks/*
!data/reference_banks/.gitkeep
data/models/*
!data/models/.gitkeep

# Local URL lists and verification artifacts can contain private/internal videos
data/reference_videos.txt
data/reference_videos*.txt
data/**/verified_urls.txt
data/**/rejected_urls.csv
data/**/verification_report.md

# Logs and caches
*.log
.cache/
.pytest_cache/
*.egg-info/
build/
dist/

# Model / embedding caches (can get large)
*.npy
*.npz
*.pkl
*.joblib

# Downloaded video files (we intentionally avoid persisting source video)
*.mp4
*.mkv
*.webm
*.avi
*.mov

# Exported YouTube Netscape cookies (session tokens; never commit)
**/youtube-cookies.txt
**/cookies-youtube.txt
**/cookies.txt
**/*cookies*.txt
